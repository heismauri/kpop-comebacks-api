{
  "name": "kpop-comebacks-api",
  "version": "2.0.0",
  "description": "API which displays the latest updates with a timestamp to convert on the users' local time",
  "main": "worker.js",
  "type": "module",
  "author": "heismauri",
  "license": "GPL-3.0",
  "scripts": {
    "dev:vite": "vite",
		"dev:worker": "wrangler dev --port 8787",
		"dev": "pnpm run dev:worker & pnpm run dev:vite",
    "deploy": "pnpm run build && wrangler deploy",
    "build": "tsc -b app/tsconfig.json && vite build",
    "lint": "eslint .",
    "test": "vitest"
  },
  "dependencies": {
    "he": "1.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@eslint/js": "^10.0.1",
    "@types/he": "^1.2.3",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "~3.2.0",
    "wrangler": "^4.90.1"
  }
}
